# LLM credentials
LLM_API_KEY=your_llm_api_key

# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Message recipient (choose one by app/settings.toml: [feishu].recipient_id_type)
FEISHU_CHAT_ID=
FEISHU_OPEN_ID=ou_xxx

# Optional: override prompt.target_keywords in settings.toml, comma-separated
NEWS_TARGET_KEYWORDS=人工智能,AI,金融,政治,科技,互联网,大宗商品,石油,黄金,能源
